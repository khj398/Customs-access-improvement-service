{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "백엔드 시작 (Express)",
      "type": "shell",
      "command": "npm install && npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/cais_back"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "프론트엔드 시작 (Flutter Web)",
      "type": "shell",
      "command": "flutter pub get && flutter run -d chrome",
      "options": {
        "cwd": "${workspaceFolder}/cais_front"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "전체 실행 (백엔드 + 프론트엔드)",
      "dependsOn": [
        "백엔드 시작 (Express)",
        "프론트엔드 시작 (Flutter Web)"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
